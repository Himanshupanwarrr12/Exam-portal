# .env.example — Template for required environment variables.
# Copy this file to .env and fill in your real values.
# NEVER commit the actual .env file to Git — add it to .gitignore.

# PostgreSQL connection string from Neon.tech (or local PostgreSQL)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# Secret key used to sign and verify JWT tokens.
# Use a long random string — anyone with this secret can forge tokens!
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your_super_secret_jwt_key_here"

# JWT expiry — how long a token stays valid before the user must log in again
JWT_EXPIRES_IN="7d"

# Port the Express server listens on
PORT=5000
